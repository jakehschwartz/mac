# Based on https://github.com/jasonmccreary/dotfiles/blob/master/.bash_prompt 

GIT_PS1_SHOWDIRTYSTATE=true
GIT_PS1_SHOWCOLORHINTS=true

PROMPT_COMMAND=__prompt_command

function __prompt_command() {

    # Find past exit code
    local rc="$?"
    exit=" "

    # If there was an error, display a red x, otherwise don't display anything
    if [ $rc != 0 ]; then
        exit="\[\033[0;31m\]✗"
    else
        exit="=>"
    fi

    # \w -> full path, relative to ~
    # %s -> git information
    __git_ps1 "\[\033[0;36m\]\w\[\033[0m\]" " $exit\[\033[0m\] " " · %s"
}

